{
  "name": "@binotype/sample",
  "version": "0.0.1",
  "description": "Sample Binotype site.",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/sample/sample.esm.js",
  "exports": {
    ".": {
      "import": "./dist/sample/sample.esm.js",
      "require": "./dist/sample/sample.cjs.js"
    },
    "./sample-site": {
      "import": "./dist/components/sample-site.js",
      "types": "./dist/components/sample-site.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/binotype/sample.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "lint": "eslint --max-warnings=0 '**/*.{ts,tsx}'",
    "fix": "eslint '**/*.{ts,tsx}' --fix",
    "build": "stencil build --prerender",
    "start": "stencil build --prerender --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate"
  },
  "devDependencies": {
    "@stencil/core": "^4.27.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.3.0"
  },
  "license": "MIT",
  "dependencies": {
    "@binotype/model": "^0.2.0",
    "tidily": "^0.2.7"
  }
}
