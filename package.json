{
	"name": "@binotype/sample",
	"version": "0.0.1",
	"license": "MIT",
	"private": false,
	"description": "Sample Binotype site.",
	"type": "module",
	"main": "dist/index.cjs.js",
	"module": "dist/index.js",
	"es2015": "dist/esm/index.js",
	"es2017": "dist/esm/index.js",
	"types": "dist/components/index.d.ts",
	"collection": "dist/collection/collection-manifest.json",
	"collection:main": "dist/collection/index.js",
	"unpkg": "dist/binotype/binotype.esm.js",
	"exports": {
		".": {
			"import": "./dist/components/index.js",
			"types": "./dist/components/index.d.ts"
		},
		"./components": {
			"import": "./dist/components/index.js",
			"types": "./dist/components/index.d.ts"
		},
		"./binotype-site": {
			"import": "./dist/components/binotype-site.js",
			"types": "./dist/components/binotype-site.d.ts"
		},
		"./collection": {
			"import": "./dist/collection/index.js",
			"types": "./dist/collection/index.d.ts"
		},
		"./hydrate": {
			"import": "./dist/hydrate/index.js",
			"types": "./dist/hydrate/index.d.ts"
		},
		"./loader": {
			"import": "./dist/loader/index.js",
			"types": "./dist/loader/index.d.ts"
		}
	},
	"files": [
		"dist/"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/binotype/sample.git"
	},
	"bugs": {
		"url": "https://github.com/binotype/sample/issues"
	},
	"homepage": "https://github.com/binotype/sample/",
	"scripts": {
		"build": "stencil build --prerender",
		"start": "stencil build --dev --watch --serve --prerender",
		"preserve": "npm run build",
		"serve": "http-server www",
		"test": "vitest --run",
		"test.watch": "vitest --watch",
		"generate": "stencil generate",
		"lint": "eslint src/**/*.{ts,tsx}",
		"format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
		"verify": "npm run lint && npm run build && npm run test"
	},
	"devDependencies": {
		"@stencil/core": "^4.43.3",
		"@stencil/sass": "^3.2.3",
		"@stencil/vitest": "^1.9.0",
		"@types/node": "^25.5.0",
		"@types/showdown": "^2.0.6",
		"@typescript-eslint/eslint-plugin": "8.57.2",
		"@typescript-eslint/parser": "8.57.2",
		"@vitest/browser-playwright": "^4.1.1",
		"@vitest/coverage-v8": "^4.1.1",
		"eslint": "^10.1.0",
		"eslint-plugin-prettier": "5.5.5",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"happy-dom": "^20.8.8",
		"http-server": "^14.1.1",
		"jsdom": "^29.0.1",
		"sass": "1.98.0",
		"stencil-inline-svg": "^1.1.0",
		"stencil-router-v2": "^0.6.0",
		"typescript": "5.9.3",
		"unplugin-stencil": "^0.4.1",
		"vitest": "^4.1.1"
	},
	"dependencies": {
		"@binotype/model": "^0.2.0",
		"isly": "^1.8.0",
		"isoly": "^3.1.8",
		"tidily": "^0.2.7"
	},
	"peerDependencies": {
		"@stencil/core": ">=4.0.0"
	}
}
