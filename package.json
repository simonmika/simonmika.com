{
	"name": "@simonmika/website",
	"version": "2.0.0-beta.0",
	"private": true,
	"description": "Website for Simon Mika, built with Binotype Site",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/simonmika/website.git"
	},
	"bugs": {
		"url": "https://github.com/simonmika/website/issues"
	},
	"homepage": "https://github.com/simonmika/website/",
	"scripts": {
		"lint": "biome format .",
		"format": "biome format --write .",
		"build": "stencil build --prerender",
		"start": "stencil build --prerender --dev --watch --serve",
		"serve": "http-server www --cors",
		"test": "vitest --run",
		"coverage": "vitest --coverage",
		"generate": "stencil generate"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@stencil/core": "4.43.4",
		"@stencil/sass": "^3.2.3",
		"@vitest/coverage-v8": "4.1.5",
		"http-server": "^14.1.1",
		"rollup-plugin-string-import": "^1.2.6",
		"stencil-inline-svg": "^1.1.0",
		"vite": "8.0.10",
		"vitest": "4.1.5"
	},
	"license": "MIT",
	"dependencies": {
		"@binotype/model": "^2.0.0-beta.3",
		"@types/node": "^25.6.0",
		"@typeup/dom": "^1.0.11-beta.3",
		"@typeup/parser": "^1.2.5-beta.3",
		"isly": "^1.9.0",
		"isoly": "^3.1.8",
		"showdown": "^2.1.0",
		"tidily": "^0.2.7",
		"yuml2svg": "^5.0.1"
	}
}
